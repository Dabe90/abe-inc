rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /inquiry_queue/{id} {
      allow read, write: if false;
    }
    match /inquiry_triage_log/{id} {
      allow read, write: if false;
    }
    match /agent_sessions/{document=**} {
      allow read, write: if false;
    }
    match /agent_session_index/{id} {
      allow read, write: if false;
    }
    match /agent_runs/{id} {
      allow read, write: if false;
    }
    match /agent_audit_log/{id} {
      allow read, write: if false;
    }
    match /agent_clients/{id} {
      allow read, write: if false;
    }
    match /agent_usage/{id} {
      allow read, write: if false;
    }
    match /match_proposals/{id} {
      allow read, write: if false;
    }
    match /coordinator_action_queue/{id} {
      allow read, write: if false;
    }
    match /events/{eventId}/{document=**} {
      allow read, write: if false;
    }
  }
}
