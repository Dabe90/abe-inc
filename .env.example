# Google AI Studio — https://aistudio.google.com/apikey
# Accepted env var names (any one):
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENAI_API_KEY=

# Optional: export traces to Firebase / Google Cloud Observability
GENKIT_ENABLE_TELEMETRY=false

# Firebase (when deploying Cloud Functions with onCallGenkit)
# GOOGLE_CLOUD_PROJECT=
# GEMINI_API_KEY=  # use defineSecret in functions for production

# Contact form endpoint (set in js/config.js after deploy)
# formEndpoint=https://us-central1-gen-lang-client-0550945038.cloudfunctions.net/submitInquiry

# Agent API auth — shared demo key OR per-client keys in Firestore agent_clients
# Production clients should use Firebase Auth ID tokens (Authorization: Bearer <idToken>)
# AGENT_API_KEY=

# Agent cost / timeout guardrails (optional global overrides)
# AGENT_TIMEOUT_MS=55000
# AGENT_MAX_TURNS=10
# AGENT_MAX_OUTPUT_TOKENS=2048
# AGENT_MAX_COST_USD=0.15

# Logging — ERROR events always write to agent_audit_log; set true for all events
# AGENT_AUDIT_LOG_TO_FIRESTORE=true
